{
  "name": "auto-api-observe",
  "version": "1.0.0",
  "description": "Zero-config observability middleware for Express and Fastify — request tracing, slow API detection, metrics, and structured JSON logs.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "build:esm": "tsc -p tsconfig.esm.json",
    "dev": "tsc --watch",
    "clean": "rimraf dist",
    "prepublishOnly": "npm run clean && npm run build",
    "example:express": "node examples/express-example.js",
    "example:fastify": "node examples/fastify-example.js",
    "example:advanced": "node examples/advanced-express.js"
  },
  "keywords": [
    "observability",
    "express",
    "fastify",
    "middleware",
    "metrics",
    "tracing",
    "logging",
    "monitoring",
    "performance",
    "apm"
  ],
  "author": "rahhuul",
  "license": "MIT",
  "peerDependencies": {
    "express": ">=4.0.0",
    "fastify": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "express": {
      "optional": true
    },
    "fastify": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.0",
    "express": "^4.18.2",
    "fastify": "^5.8.1",
    "rimraf": "^5.0.5",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rahhuul/auto-api-observe.git"
  },
  "bugs": {
    "url": "https://github.com/rahhuul/auto-api-observe/issues"
  },
  "homepage": "https://github.com/rahhuul/auto-api-observe#readme"
}
