{
  "name": "auto-api-observe",
  "version": "1.4.0",
  "description": "Zero-config observability for Node.js APIs — Express, Fastify, Koa, Hono, NestJS, Next.js, Hapi, Elysia, Apollo, Lambda, tRPC, Restify. Request tracing, DB profiling, slow-request detection, and real-time metrics.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "build:esm": "tsc -p tsconfig.esm.json",
    "dev": "tsc --watch",
    "clean": "rimraf dist",
    "prepublishOnly": "npm run clean && npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "example:express": "node examples/express-example.js",
    "example:fastify": "node examples/fastify-example.js",
    "example:advanced": "node examples/advanced-express.js",
    "example:cloud": "node examples/cloud-express.js"
  },
  "keywords": [
    "observability",
    "express",
    "fastify",
    "koa",
    "hono",
    "nestjs",
    "nextjs",
    "hapi",
    "elysia",
    "apollo",
    "lambda",
    "trpc",
    "restify",
    "middleware",
    "metrics",
    "tracing",
    "logging",
    "monitoring",
    "performance",
    "apm",
    "api-monitoring",
    "request-logging",
    "api-analytics",
    "express-middleware",
    "fastify-plugin",
    "structured-logging",
    "distributed-tracing",
    "slow-request-detection",
    "db-profiling",
    "error-tracking",
    "node-monitoring"
  ],
  "author": "rahhuul",
  "license": "MIT",
  "peerDependencies": {
    "express": ">=4.0.0",
    "fastify": ">=4.0.0",
    "koa": ">=2.0.0",
    "hono": ">=3.0.0",
    "@nestjs/common": ">=9.0.0",
    "rxjs": ">=7.0.0",
    "@hapi/hapi": ">=20.0.0",
    "elysia": ">=0.7.0",
    "@apollo/server": ">=4.0.0",
    "next": ">=13.0.0"
  },
  "peerDependenciesMeta": {
    "express": {
      "optional": true
    },
    "fastify": {
      "optional": true
    },
    "koa": {
      "optional": true
    },
    "hono": {
      "optional": true
    },
    "@nestjs/common": {
      "optional": true
    },
    "rxjs": {
      "optional": true
    },
    "@hapi/hapi": {
      "optional": true
    },
    "elysia": {
      "optional": true
    },
    "@apollo/server": {
      "optional": true
    },
    "next": {
      "optional": true
    }
  },
  "optionalDependencies": {
    "ws": "^8.0.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.0",
    "@types/ws": "^8.5.10",
    "express": "^4.18.2",
    "fastify": "^5.8.1",
    "rimraf": "^5.0.5",
    "typescript": "^5.3.3",
    "vitest": "^1.3.1"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rahhuul/auto-api-observe.git"
  },
  "bugs": {
    "url": "https://github.com/rahhuul/auto-api-observe/issues"
  },
  "homepage": "https://apilens.rest"
}
